# tests/e2e/secrets.local.env — TEMPLATE (this file is committed,
# secrets.local.env is gitignored). Copy to secrets.local.env, fill the
# ones you have. Tests that require a missing secret skip with a clear
# message, they do not fail.
#
# Loading order: testenv.RequireSecret looks at os.Getenv first, then
# this file. CI usually sets env vars and skips this file entirely.
#
# Rule: ONE secret per line, no expansion, no quoting unless the value
# itself contains spaces. Tests treat KEY="value" the same as KEY=value.

# ─── LLM providers (live mode for chat / RCA suites) ──────────────────
# Anthropic-compatible relay (one-api / new-api / official). Set the URL
# of the deployment you want tests to hit. Leave empty to skip.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
# Zhipu official endpoint or compatible relay. Format: id.secret.
ZHIPU_API_KEY=
ZHIPU_BASE_URL=
# OpenAI / proxy. Default base = https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ─── Slack live integration (Notifications + IM Channel) ──────────────
# Incoming Webhook URL for the Notifications side (G3 live).
SLACK_INCOMING_WEBHOOK_URL=
# Socket Mode app token (xapp-...) + bot token (xoxb-...) for the
# Channels side (H3, H4 live). Workspace team_id (T...) optional —
# fakes inject it from app_id when missing.
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
SLACK_WORKSPACE_ID=
SLACK_BOT_USER_ID=

# ─── Telegram live integration ────────────────────────────────────────
# BotFather token (no "bot" prefix; raw "<id>:<hash>").
TELEGRAM_BOT_TOKEN=
TELEGRAM_TEST_CHAT_ID=
TELEGRAM_TEST_USER_ID=

# ─── Larksuite / DingTalk / WeCom incoming webhook (G4–G6 live) ───────
LARKSUITE_WEBHOOK_URL=
LARKSUITE_WEBHOOK_SECRET=
DINGTALK_WEBHOOK_URL=
DINGTALK_WEBHOOK_SECRET=
WECOM_WEBHOOK_URL=

# ─── git / vault sync (K4, K5 live) ───────────────────────────────────
# Read-only deploy key for a known private repo used by K5 test.
GIT_SSH_PRIVATE_KEY_PATH=
GIT_TEST_PRIVATE_REPO_URL=

# ─── outbound HTTP proxy (mainland-China test env) ────────────────────
# Set if testenv needs to dial slack.com / api.telegram.org via a proxy.
# Honors standard env shape: http://host:port or socks5://host:port.
E2E_HTTPS_PROXY=
E2E_NO_PROXY=

# ─── live-mode toggles ────────────────────────────────────────────────
# Default 0. Set to 1 to enable a live-mode suite. Even with 1, individual
# tests still RequireSecret() so missing tokens skip cleanly.
E2E_LIVE_LLM=0
E2E_LIVE_SLACK=0
E2E_LIVE_TELEGRAM=0
E2E_LIVE_LARKSUITE=0
E2E_LIVE_GIT=0
E2E_LIVE_ALL=0
